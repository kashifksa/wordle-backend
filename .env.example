# Server
PORT=3000
API_BASE_URL=/api/wordle
CORS_ORIGIN=*

# Time & Scheduling
TIMEZONE=Asia/Karachi
CRON_SCHEDULE=5 14 * * *
RETRY_INTERVAL_MIN=5
RETRY_MAX_ATTEMPTS=12

# Scraper
SCRAPE_URL=https://www.nytimes.com/games/wordle/index.html
SCRAPE_TIMEOUT_MS=10000
SCRAPE_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"

# AI (Hints)
AI_API_KEY=your_openai_or_other_key
AI_MODEL=gpt-4o
AI_PROMPT_TEMPLATE="Generate hints for the Wordle word: {{WORD}}. Return JSON with keys: hint1 (vague), hint2 (category), hint3 (specific), final_hint (strong)."

# Security
API_KEY=your_secret_api_key

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=wordle_db
DB_POOL_SIZE=5

# Feature Flags
ENABLE_CACHE=true
ENABLE_FALLBACK_HINTS=true
