# Server
PORT=3000
API_BASE_URL=/api/wordle
CORS_ORIGIN=*

# Time & Scheduling
TIMEZONE=Asia/Karachi
CRON_SCHEDULE=35 15 * * *
RETRY_INTERVAL_MIN=5
RETRY_MAX_ATTEMPTS=12

# Wordle Base Date reference
BASE_PUZZLE_NUMBER=1771
BASE_DATE=2026-04-25

# Scraper
SCRAPE_BASE_NYT=https://www.nytimes.com
SCRAPE_BASE_NYT_API=https://www.nytimes.com/svc/wordle/v2
SCRAPE_CNET_PATTERN=https://www.cnet.com/tech/gaming/todays-wordle-hints-answer-and-help-for-{{DATE}}-{{PUZZLE_NUMBER}}/
SCRAPE_MASHABLE_PATTERN=https://mashable.com/article/wordle-today-answer-{{DATE}}
SCRAPE_WORDTIPS_URL=https://word.tips/todays-wordle-answer/
SCRAPE_TIMEOUT_MS=10000
SCRAPE_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"

# AI (Hints)
AI_API_URL=https://api.groq.com/openai/v1/chat/completions
AI_API_KEY=your_groq_api_key
AI_MODEL=llama-3.1-8b-instant
AI_PROMPT_TEMPLATE="Generate hints for the Wordle word: {{WORD}}. Do NOT say the word has 5 letters. Return JSON with keys: hint1 (part of speech or vague meaning), hint2 (category), hint3 (specific), final_hint (strong)."

# Security
API_KEY=your_secret_api_key

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=wordle_db
DB_POOL_SIZE=5

# Feature Flags
ENABLE_CACHE=true
ENABLE_FALLBACK_HINTS=true
